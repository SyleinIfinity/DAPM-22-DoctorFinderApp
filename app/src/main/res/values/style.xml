<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="boxBackgroundColor">@color/surface_color</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextColor">@color/teal_primary</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- ===== TextInputLayout – Small (inside Doctor Card) ===== -->
    <style name="Widget.App.TextInputLayout.Small" parent="Widget.App.TextInputLayout">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ===== Primary Button ===== -->
    <style name="Widget.App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">@color/teal_ripple</item>
        <item name="elevation">4dp</item>
    </style>
    <style name="Theme.BacSiTheoDoiUI" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Doctor Card Button: Outline -->
    <style name="Widget.App.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Doctor Card Button: Filled -->
    <style name="Widget.App.Button.Filled" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Tab style -->
    <style name="Widget.App.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextColor">@color/tab_inactive</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabTextAppearance">@style/TextAppearance.App.Tab</item>
        <item name="android:background">@color/white</item>
        <item name="tabGravity">fill</item>
        <item name="tabMode">fixed</item>
    </style>

    <style name="TextAppearance.App.Tab" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemTextColor">@color/bottom_nav_color_selector</item>
        <item name="itemIconTint">@color/bottom_nav_color_selector</item>
        <item name="android:background">@color/white</item>
        <item name="elevation">8dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.App.BottomNav</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.App.BottomNav</item>
        <item name="labelVisibilityMode">unlabeled</item>
        <item name="itemBackground">@drawable/bg_bottom_nav_item</item>
        <item name="itemIconSize">24dp</item>
    </style>

    <style name="TextAppearance.App.BottomNav" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.App.DoctorCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_marginStart">@dimen/card_margin_h</item>
        <item name="android:layout_marginEnd">@dimen/card_margin_h</item>
        <item name="android:layout_marginTop">@dimen/card_margin_v</item>
        <item name="android:layout_marginBottom">@dimen/card_margin_v</item>
    </style>


    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryLight</item>
        <item name="colorOnPrimary">@color/colorWhite</item>
        <item name="android:windowBackground">@color/colorBackground</item>
    </style>

    <!-- ─── TIME SLOT STYLES ─── -->

    <!-- Default slot: border teal, text teal -->
    <style name="SlotDefault">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:background">@drawable/bg_slot_default</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Selected slot: filled teal, text white -->
    <style name="SlotSelected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:background">@drawable/bg_slot_selected</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Full slot: gray border, gray text, gray bg -->
    <style name="SlotFull">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorSlotFullText</item>
        <item name="android:background">@drawable/bg_slot_full</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
    </style>


    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.TabLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
    </style>

    <!-- ===== SLOT BUTTON STYLES ===== -->

    <!-- Slot: còn trống (CHI_TIET_LICH.trangThai = TRONG) -->
    <style name="Widget.Slot.Available" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/slot_available_text</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Slot: đã đặt / đang giữ (DANG_GIU / DA_DAT) -->
    <style name="Widget.Slot.Full" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/slot_full_text</item>
        <item name="android:backgroundTint">@color/slot_full_bg</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:enabled">false</item>
    </style>

    <!-- Slot: đang chọn (selected) -->
    <style name="Widget.Slot.Selected" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/slot_selected_text</item>
        <item name="android:backgroundTint">@color/slot_selected_bg</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- ===== SHAPE APPEARANCE ===== -->
    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
