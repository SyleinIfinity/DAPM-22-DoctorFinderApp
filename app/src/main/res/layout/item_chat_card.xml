<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="48dp"
    android:layout_marginEnd="24dp"
    android:orientation="vertical"
    android:background="@drawable/bg_chat_bubble_received"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivCardIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_lightbulb"
            app:tint="@color/primary"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvCardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gợi ý chuyên khoa"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCardDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Dựa trên triệu chứng, bạn nên khám chuyên khoa Thần kinh."
        android:textColor="#333333"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
