<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout cho mỗi item bác sĩ đã theo dõi trong RecyclerView của FollowFragment.
    File: item_follow_doctor.xml
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Avatar vòng tròn -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp">

            <!-- Ảnh đại diện từ URL (Glide) -->
            <ImageView
                android:id="@+id/ivDoctorAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="Avatar bác sĩ" />

            <!-- Chữ initials (hiện khi không có ảnh) -->
            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/bg_avatar_circle"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Thông tin bác sĩ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên bác sĩ"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tvSpecialty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chuyên khoa"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_home"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bệnh viện"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextMuted" />

            </LinearLayout>

        </LinearLayout>

        <!-- Mũi tên điều hướng -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            android:contentDescription="@null"
            android:alpha="0.4" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
