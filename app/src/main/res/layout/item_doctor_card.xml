<?xml version="1.0" encoding="utf-8"?>
<!--
    Item: Card bác sĩ trong danh sách theo dõi
    File: item_doctor_card.xml
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/card_margin_h"
    android:layout_marginEnd="@dimen/card_margin_h"
    android:layout_marginTop="@dimen/card_margin_v"
    android:layout_marginBottom="@dimen/card_margin_v"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- ── ROW 1: Avatar + Info + Heart ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar container (relative for online dot badge) -->
            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp">

                <!-- Avatar image -->
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_bulb_circle"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_doctor_placeholder"
                    android:contentDescription="Ảnh bác sĩ" />

                <!-- Online dot badge -->
                <View
                    android:id="@+id/vOnlineDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/ic_online_dot"
                    android:visibility="visible" />

            </FrameLayout>

            <!-- Doctor info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_xs">

                <!-- Name -->
                <TextView
                    android:id="@+id/tvDoctorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PGS.TS Nguyễn Anh"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_lg"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Specialty -->
                <TextView
                    android:id="@+id/tvSpecialty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Thần kinh"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif" />

                <!-- Rating + Experience row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <!-- Star icon -->
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        android:contentDescription="Sao"
                        app:tint="@color/star_yellow" />

                    <!-- Rating score -->
                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="4.9"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Review count -->
                    <TextView
                        android:id="@+id/tvReviewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="(120 đánh giá)"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <!-- Spacer -->
                    <Space
                        android:layout_width="@dimen/spacing_md"
                        android:layout_height="1dp" />

                    <!-- Briefcase icon -->
                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_briefcase"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Kinh nghiệm"
                        tools:ignore="UseAppTint" />

                    <!-- Experience years -->
                    <TextView
                        android:id="@+id/tvExperience"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="15 năm"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

                <!-- Distance + Status row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <!-- Location icon -->
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_location_pin"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Khoảng cách"
                        tools:ignore="UseAppTint" />

                    <!-- Distance -->
                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="1.2 km"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <!-- Separator dot -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        android:text="•"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <!-- Status: "Dang online" or "Có lịch hôm nay" -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Có lịch hôm nay"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

            <!-- Heart / Unfollow button -->
            <ImageButton
                android:id="@+id/btnHeart"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_heart_filled"
                android:tint="@color/heart_red"
                android:contentDescription="Bỏ theo dõi"
                tools:ignore="UseAppTint" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:background="@color/divider" />

        <!-- ── ROW 2: Action Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Xem chi tiết (outline) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDetail"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="@string/xem_chi_tiet"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:fontFamily="sans-serif-medium"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                app:cornerRadius="24dp" />

            <!-- Đặt lịch (filled) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBooking"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="@string/dat_lich"
                android:textColor="@color/white"
                android:textSize="@dimen/text_sm"
                android:fontFamily="sans-serif-medium"
                style="@style/Widget.MaterialComponents.Button"
                app:backgroundTint="@color/primary"
                app:cornerRadius="24dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
