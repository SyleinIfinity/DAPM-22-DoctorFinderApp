<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutChatRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_avatar_teal"
            android:src="@drawable/ic_doctor_placeholder"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_online_dot"
            android:visibility="visible" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BS. Nguyễn Anh"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary" />

        <TextView
            android:id="@+id/tvLastMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn có thể đặt lịch vào ngày mai..."
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:41"
            android:textSize="11sp"
            android:textColor="@color/text_muted" />

        <TextView
            android:id="@+id/tvUnread"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_badge_teal"
            android:gravity="center"
            android:text="2"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:visibility="visible" />
    </LinearLayout>

</LinearLayout>
