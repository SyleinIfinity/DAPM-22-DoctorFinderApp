<?xml version="1.0" encoding="utf-8"?>
<!--
    item_info_row.xml
    Hàng thông tin (icon vuông + label + value) trong card Thông tin chuyên môn
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/bg_divider_bottom">

    <!-- Icon nền vuông bo góc -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="1dp"
        android:background="@drawable/bg_info_icon">

        <ImageView
            android:id="@+id/ivInfoIcon"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_activity"
            android:contentDescription="@null" />

    </FrameLayout>

    <!-- Label + Value -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/colorTextHint"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvInfoValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/colorTextPrimary" />

    </LinearLayout>

</LinearLayout>