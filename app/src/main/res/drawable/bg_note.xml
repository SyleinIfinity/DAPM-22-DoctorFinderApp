<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_note" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_primary" />
            <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp"
                android:topRightRadius="0dp" android:bottomRightRadius="0dp" />
            <size android:width="2dp" />
        </shape>
    </item>
</layer-list>